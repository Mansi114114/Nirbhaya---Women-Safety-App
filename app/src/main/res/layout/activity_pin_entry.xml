<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- App title for disguise mode -->
    <TextView
        android:id="@+id/app_disguise_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="Calculator"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Calculator Layout (for disguise mode) -->
    <LinearLayout
        android:id="@+id/calculator_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/app_disguise_title"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Calculator Display -->
        <TextView
            android:id="@+id/calculator_display"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#EEEEEE"
            android:gravity="end|center_vertical"
            android:padding="12dp"
            android:textSize="30sp" />

        <!-- Calculator Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/calculator_button_7"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="7"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_8"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="8"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_9"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="9"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_divide"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="÷"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/calculator_button_4"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="4"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_5"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="5"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_6"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="6"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_multiply"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="×"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/calculator_button_1"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="1"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_2"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="2"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_3"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="3"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_subtract"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="-"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/calculator_button_0"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="0"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_clear"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="C"
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_equals"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="="
                android:textSize="24sp" />

            <Button
                android:id="@+id/calculator_button_add"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="+"
                android:textSize="24sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- PIN Entry Layout -->
    <LinearLayout
        android:id="@+id/pin_entry_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Enter your security PIN"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/pin_entry_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="PIN"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:textAlignment="center" />

        <Button
            android:id="@+id/submit_pin_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Submit" />
    </LinearLayout>
</RelativeLayout>